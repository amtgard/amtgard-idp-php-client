IDP_BASE_URL=https://idp.amtgard.com
IDP_CLIENT_ID=your-registered-client-id
IDP_CLIENT_SECRET=your-confidential-client-secret
IDP_REDIRECT_URI=http://localhost:38080/oauth/callback
# Optional — library default is AmtgardIDP/1.0
# IDP_HTTP_USER_AGENT=AmtgardIDP/1.0
# Demo defaults for POST /api/check-authorization and POST /api/client-iam/compose-claim
EXAMPLE_POLICY=["Idp:0:0:0:0:IDP/EditClient"]
EXAMPLE_POLICY_REQUIREMENT=Idp:0:0:0:0:IDP/EditClient
# Optional — offline Client IAM prefix when GET service-format returns is_default without iam_service
# IDP_IAM_SERVICE=Idp
# IDP_IAM_SERVICE_FORMAT=["Configuration","Game","Kingdom","Park"]
