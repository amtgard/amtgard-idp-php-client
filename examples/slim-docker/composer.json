{
    "name": "amtgard/idp-slim-docker-example",
    "description": "Dockerized Slim 4 reference app for amtgard/idp-php-client",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "amtgard/idp-php-client": "@dev",
        "guzzlehttp/guzzle": "^7.9",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.4",
        "slim/slim": "^4.14",
        "vlucas/phpdotenv": "^5.6"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Amtgard\\IdpSlimExample\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
