{
    "name": "amtgard/idp-php-client",
    "description": "Opinionated PHP client for the Amtgard Identity Provider OAuth 2.0 and resource API",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "league/oauth2-client": "^2.7",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1|^2.0",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.9",
        "nyholm/psr7-server": "^1.1",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "slim/slim": "^4.14",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "suggest": {
        "guzzlehttp/guzzle": "PSR-18 HTTP client (recommended for most apps)",
        "slim/slim": "Use Amtgard\\IdpClient\\Slim\\IdpAuthController and SessionMiddleware"
    },
    "autoload": {
        "psr-4": {
            "Amtgard\\IdpClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amtgard\\IdpClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text --coverage-clover=build/coverage.xml --coverage-filter=src",
        "integration:slim:up": "sh -c 'test -f examples/slim-docker/.env || cp examples/slim-docker/.env.example examples/slim-docker/.env; docker compose -f examples/slim-docker/docker-compose.yml up --build -d'",
        "integration:slim:down": "docker compose -f examples/slim-docker/docker-compose.yml down",
        "integration:slim": [
            "@integration:slim:up",
            "@php -r \"sleep(3);\"",
            "SLIM_INTEGRATION=1 phpunit --testsuite Integration --filter SlimDocker"
        ],
        "stan": "phpstan analyse src tests",
        "cs": "phpcs"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
